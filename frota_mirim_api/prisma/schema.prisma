generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum VehicleType {
  CARRO
  CAMINHAO
  MOTO
  ONIBUS
}

enum FuelType {
  GASOLINA
  ETANOL
  DIESEL
}

enum FuelStationType {
  INTERNO
  EXTERNO
}

enum UserRole {
  ADMIN
  MOTORISTA
  AUXILIAR
  EDITOR
}

enum VehicleUsageType {
  ENTRY
  EXIT
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum ItemType {
  PART
  SERVICE
}

enum PerformerType {
  INTERNAL
  EXTERNAL
}

enum StockReferenceType {
  MAINTENANCE
  PURCHASE
  ADJUSTMENT
}

enum StockMovementType {
  IN
  OUT
  ADJUST
}

enum AlertType {
  // ESTOQUE
  LOW_STOCK
  ZERO_STOCK

  // MANUTENÇÃO
  MAINTENANCE_DUE
  MAINTENANCE_OVERDUE
  MAINTENANCE_OPEN_TOO_LONG
  MAINTENANCE_IN_PROGRESS_TOO_LONG

  // DOCUMENTOS
  VEHICLE_DOCUMENT_EXPIRING
  VEHICLE_DOCUMENT_EXPIRED

  // ABASTECIMENTO
  FUEL_CONSUMPTION_ANOMALY

  // USO DO VEÍCULO
  VEHICLE_CHECKOUT_TOO_LONG
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertEntityType {
  STOCK_ITEM
  VEHICLE
  MAINTENANCE
  FUEL_SUPPLY
  DOCUMENT
}

// USER
model User {
  id           String @id @default(uuid())
  internalCode Int    @unique

  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true)

  cpf String @unique @db.VarChar(11)

  imageUrl     String?
  cnhExpiresAt DateTime?

  fuelSupplies FuelSupply[]
  userPhones   UserPhone[]

  vehicleUsagesAsDriver    VehicleUsage[] @relation("Driver")
  vehicleUsagesAsAssistant VehicleUsage[] @relation("Assistant")

  performedMaintenances MaintenanceOrder[] @relation("MaintenancePerformedByUser")
  createdMaintenances   MaintenanceOrder[] @relation("MaintenanceCreatedBy")
  updatedMaintenances   MaintenanceOrder[] @relation("MaintenanceUpdatedBy")
  stockMovementsCreated StockMovement[]    @relation("StockMovementCreatedByUser")

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  stockMovements    StockMovement[]
  maintenanceOrders MaintenanceOrder[]

  @@index([isActive])
  @@index([role])
}

// TELEFONES
model UserPhone {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone String @unique @db.VarChar(20)

  isPrimary Boolean   @default(false)
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  maintenanceOrders MaintenanceOrder[]

  @@index([userId])
  @@index([isActive])
  @@index([isPrimary])
}

// VEHICLE
model Vehicle {
  id     String      @id @default(uuid())
  placa  String      @unique
  modelo String
  marca  String
  ano    Int
  tipo   VehicleType

  kmAtual               Int
  kmUltimoAbastecimento Int?

  ipvaDueMonth      Int @default(1)
  licensingDueMonth Int @default(1)
  ipvaPaidYear      Int?
  licensingPaidYear Int?

  isActive Boolean @default(true)

  fuelSupplies  FuelSupply[]
  vehicleUsages VehicleUsage[]

  maintenances MaintenanceOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
  @@index([isActive])
  @@index([ipvaDueMonth])
  @@index([licensingDueMonth])
}

// FUEL SUPPLY (ABASTECIMENTO)
model FuelSupply {
  id String @id @default(uuid())

  // RELAÇÕES

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // DADOS DO ABASTECIMENTO
  data            DateTime
  kmAtual         Int
  litros          Decimal         @db.Decimal(10, 3)
  valorLitro      Decimal         @db.Decimal(10, 3)
  valorTotal      Decimal         @db.Decimal(12, 2)
  tipoCombustivel FuelType
  postoTipo       FuelStationType
  postoNome       String?
  tanqueCheio     Boolean         @default(false)

  // Média calculada somente quando tanqueCheio = true
  media Decimal? @db.Decimal(10, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // INDEXAÇÃO PARA PERFORMANCE
  @@index([vehicleId])
  @@index([userId])
  @@index([data])
  @@index([tipoCombustivel])
  @@index([tanqueCheio])
}

// USO DO VEÍCULO (ENTRADAS E SAÍDAS)
model VehicleUsage {
  id String @id @default(uuid())

  // RELAÇÕES
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // MOTORISTA (OBRIGATÓRIO)
  userId String
  user   User   @relation("Driver", fields: [userId], references: [id], onDelete: Restrict)

  // AUXILIAR (OPCIONAL)
  assistantId String?
  assistant   User?   @relation("Assistant", fields: [assistantId], references: [id], onDelete: SetNull)

  // EVENTO
  type    VehicleUsageType
  eventAt DateTime
  km      Int
  notes   String?

  createdAt DateTime @default(now())

  @@index([vehicleId, eventAt])
  @@index([userId, eventAt])
  @@index([assistantId, eventAt])
  @@index([type])
}

// CATÁLOGO DE ITENS (PEÇAS E SERVIÇOS)
model ItemCatalog {
  id String @id @default(uuid())

  name         String
  type         ItemType
  reference    String?
  defaultPrice Decimal? @db.Decimal(12, 2)

  isStockItem Boolean @default(false)
  isActive    Boolean @default(true)

  maintenanceItems MaintenanceItem[]

  stockItem      StockItem?
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isStockItem])
  @@index([isActive])
  @@index([name])
  @@index([reference])
}

// ESTOQUE DE ITENS (PEÇAS)
model StockItem {
  id String @id @default(uuid())

  itemCatalogId String      @unique
  itemCatalog   ItemCatalog @relation(fields: [itemCatalogId], references: [id], onDelete: Cascade)

  currentQuantity Int  @default(0)
  minimumQuantity Int?

  location String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// MOVIMENTAÇÃO DE ESTOQUE (ENTRADAS, SAÍDAS E AJUSTES)
model StockMovement {
  id String @id @default(uuid())

  itemCatalogId String
  itemCatalog   ItemCatalog @relation(fields: [itemCatalogId], references: [id], onDelete: Restrict)

  type     StockMovementType
  quantity Int

  unitCost  Decimal? @db.Decimal(12, 2)
  totalCost Decimal? @db.Decimal(12, 2)

  reason String?

  referenceType StockReferenceType?
  referenceId   String?

  createdByUserId String?
  createdByUser   User?   @relation("StockMovementCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([itemCatalogId])
  @@index([createdAt])
  @@index([referenceId])
  @@index([referenceType])
}

// ORDEM DE MANUTENÇÃO
model MaintenanceOrder {
  id         String @id @default(uuid())
  sequenceId Int    @unique

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  type   MaintenanceType
  status MaintenanceStatus @default(OPEN)

  description String?

  odometer Int

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  performerType PerformerType

  performedByUserId String?
  performedByUser   User?   @relation("MaintenancePerformedByUser", fields: [performedByUserId], references: [id], onDelete: SetNull)

  performedByExternal String?

  partsCost    Decimal @default(0) @db.Decimal(12, 2)
  servicesCost Decimal @default(0) @db.Decimal(12, 2)
  totalCost    Decimal @default(0) @db.Decimal(12, 2)

  notes String?

  createdByUserId String?
  createdByUser   User?   @relation("MaintenanceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  updatedByUserId String?
  updatedByUser   User?   @relation("MaintenanceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  maintenanceItems MaintenanceItem[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User?      @relation(fields: [userId], references: [id])
  userId      String?
  userPhone   UserPhone? @relation(fields: [userPhoneId], references: [id])
  userPhoneId String?

  @@index([vehicleId])
  @@index([status])
  @@index([type])
  @@index([completedAt])
  @@index([vehicleId, status])
  @@index([vehicleId, completedAt])
}

// ITENS DE MANUTENÇÃO (PEÇAS E SERVIÇOS UTILIZADOS NAS ORDENS DE MANUTENÇÃO)
model MaintenanceItem {
  id String @id @default(uuid())

  maintenanceOrderId String
  maintenanceOrder   MaintenanceOrder @relation(fields: [maintenanceOrderId], references: [id], onDelete: Cascade)

  itemCatalogId String
  itemCatalog   ItemCatalog @relation(fields: [itemCatalogId], references: [id], onDelete: Restrict)

  nameSnapshot      String
  referenceSnapshot String?
  typeSnapshot      ItemType

  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([maintenanceOrderId])
  @@index([itemCatalogId])
  @@index([typeSnapshot])
}

// ALERTAS
model Alert {
  id String @id @default(uuid())

  // ID para exibição
  sequenceId Int @unique @default(autoincrement())

  type     AlertType
  severity AlertSeverity

  title   String
  message String

  entityType AlertEntityType
  entityId   String?

  // dados adicionais do alerta (flexível)
  metadata Json?

  isRead Boolean   @default(false)
  readAt DateTime?

  // quando o problema foi resolvido
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([entityType, entityId])
  @@index([isRead])
  @@index([createdAt])
}

// JOBS DE SISTEMA (para tarefas agendadas, como envio de notificações, cálculos periódicos, etc)
model SystemJob {
  id      String    @id @default(cuid())
  job     String    @unique
  lastRun DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
